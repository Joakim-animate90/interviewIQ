# --- Server ---
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Server port (defaults to 8787 if unset)
PORT=8787

# CORS — comma-separated list of allowed origins for the API
# In development, the Vite proxy makes this irrelevant.
# In production (single container) leave empty: the server serves the client.
CORS_ORIGIN=

# Node environment
NODE_ENV=development

# --- Client ---
# Where the client should call the API. In dev, leave empty to use the Vite proxy.
# In production builds served by the same Express process, leave empty as well.
VITE_API_BASE_URL=
